{
    "appId":  "com.eduaitor.app",
    "appName":  "Eduaitor",
    "webDir":  "dist",
    "server":  {
                   "url":  "https://admineduaitor.netlify.app",
                   "cleartext":  false,
                   "androidScheme":  "https",
                   "allowNavigation":  [
                                           "admineduaitor.netlify.app",
                                           "*.netlify.app",
                                           "eduaitor-api.onrender.com"
                                       ]
               },
    "android":  {
                    "allowMixedContent":  false,
                    "backgroundColor":  "#0f172a"
                },
    "plugins":  {
                    "SplashScreen":  {
                                         "launchAutoHide":  true,
                                         "backgroundColor":  "#0f172a",
                                         "showSpinner":  false
                                     },
                    "StatusBar":  {
                                      "overlaysWebView":  false,
                                      "style":  "LIGHT",
                                      "backgroundColor":  "#ffffff"
                                  }
                }
}
