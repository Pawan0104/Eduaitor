# Copy to .env locally. On Render, set these in the dashboard (Environment).

NODE_ENV=production
PORT=5000

# Required on Render
USE_ATLAS_DB=true
MONGO_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/Eduaitor?retryWrites=true&w=majority

JWT_SECRET=change-me-to-a-long-random-string

# Netlify site origin (no trailing slash)
CLIENT_URL=https://your-site.netlify.app
# Optional extra origins (comma-separated)
# CLIENT_URLS=https://www.your-domain.com,https://deploy-preview-1--your-site.netlify.app

SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-me

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

OPENROUTER_API_KEY=
# OPENAI_API_KEY=
