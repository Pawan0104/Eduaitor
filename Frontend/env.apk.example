# Copy to .env.apk (used by: npm run build:apk)
VITE_API_URL=https://eduaitor-api.onrender.com/api
VITE_APP_URL=https://admineduaitor.netlify.app

# Note: Debug APK loads VITE_APP_URL live via capacitor.config.json server.url
